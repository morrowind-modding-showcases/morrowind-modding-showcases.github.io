{
  "schemaVersion": 1,
  "selection": {
    "strategy": "highest-priority",
    "description": "A modder receives the eligible title with the highest numeric priority. Priorities are unique; higher values represent rarer combinations or more advanced release thresholds.",
    "priorityFormula": "Add each focus rarityWeight multiplied by its required count, add 15 for each focus after the first, multiply by 100, then add the title's 1-based source row as a deterministic tie-breaker."
  },
  "focuses": {
    "character-customization-mods": {

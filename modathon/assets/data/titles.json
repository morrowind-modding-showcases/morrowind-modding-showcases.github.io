      "rarityWeight": 10
    },
    "modding-categories": {
      "label": "Distinct Modding Categories",
      "type": "distinct-mod-categories",
      "exclude": [
        "Unknown"
      ],
      "rarityWeight": 7
    },
    "most-downloaded-achievements": {
      "label": "Most Downloaded Achievements",
      "type": "achievement",
      "match": {
        "all": [
          {
            "field": "requirement",
            "equals": "Most Downloaded Mod"
          }
        ]
      },
      "rarityWeight": 60
    },
    "championship-achievements": {
      "label": "Any Championship Achievement",
      "type": "achievement",
      "match": {
        "any": [
          {
            "field": "name",
            "startsWith": "Champion "
          },
          {
            "field": "requirement",
            "startsWith": "Release the most popular"
          }
        ]
      },
      "rarityWeight": 40
    },
    "challenge-accepted-achievements": {
      "label": "Themed Challenge Accepted Achievement",
      "type": "achievement",
      "match": {
        "all": [
          {
            "field": "name",
            "equals": "Challenge Accepted"
          }
        ]
      },
      "rarityWeight": 55
    },
    "themed-challenge-achievements": {
      "label": "Themed Challenge Achievements",
      "type": "achievement",
      "match": {
        "all": [
          {
            "field": "group",
            "equals": "challenge"
          }
        ]
      },
      "rarityWeight": 12
    },
    "hidden-achievements": {
      "label": "Hidden Achievement Unlocks",
      "type": "achievement",
      "match": {
        "any": [
          {
            "field": "group",
            "startsWith": "hidden"
          },
          {
            "field": "rarityKey",
            "includes": "hidden"
          }
        ]
      },
      "rarityWeight": 18
    },
    "gameplay-champion-achievements": {
      "label": "Gameplay Champion Achievements",
      "type": "achievement",
      "match": {
        "all": [
          {
            "field": "requirement",
            "startsWith": "Release the most popular"
          },
          {
            "field": "requirement",
            "includesAny": [
              "Gameplay",
              "Bug Fix",
              "Patch",
              "UI"
            ]
          }
        ]
      },
      "rarityWeight": 50
    },
    "towns-and-cities-champion-achievements": {
